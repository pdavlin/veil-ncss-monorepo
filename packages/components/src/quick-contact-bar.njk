{#
  quick-contact-bar — mobile-only sticky-bottom row of contact actions
  (phone / email / social). Hidden on desktop; lives in the base layout so
  every page surfaces these affordances on small screens.

  Expects on `site`:
    founders[0].{phone, email}    primary contact for the tel:/mailto: links
    social[]                       additional links (e.g. LinkedIn)
#}
{% if site.founders or site.social %}
  <nav class="quick-contact-bar" data-component="quick-contact-bar" aria-label="Quick contact">
    <ul class="quick-contact-bar__list">
      {% if site.founders and site.founders[0].phone %}
        <li>
          <a href="tel:{{ site.founders[0].phone | replace('.', '') | replace(' ', '') | replace('-', '') }}" aria-label="Phone {{ site.founders[0].name }}">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" fill="currentColor"/></svg>
          </a>
        </li>
      {% endif %}
      {% if site.founders and site.founders[0].email %}
        <li>
          <a href="mailto:{{ site.founders[0].email }}" aria-label="Email {{ site.founders[0].name }}">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" fill="currentColor"/></svg>
          </a>
        </li>
      {% endif %}
      {% for s in site.social %}
        <li>
          <a href="{{ s.href }}" rel="noopener" aria-label="{{ s.label }}">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M19 3H5c-1.105 0-2 .895-2 2v14c0 1.105.895 2 2 2h14c1.105 0 2-.895 2-2V5c0-1.105-.895-2-2-2zM8.339 18.337H5.665v-8.59h2.674v8.59zM7.003 8.574a1.548 1.548 0 110-3.096 1.548 1.548 0 010 3.096zm11.335 9.763h-2.669V14.16c0-.996-.018-2.277-1.388-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248h-2.667v-8.59h2.56v1.174h.037c.355-.675 1.227-1.387 2.524-1.387 2.704 0 3.203 1.78 3.203 4.092v4.71z" fill="currentColor"/></svg>
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
{% endif %}
