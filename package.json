{
  "name": "veil-ncss-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Veil + NCSS site redesign monorepo. Phase 3: shared components + Veil site.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build && pnpm -r --filter \"./sites/**\" run build",
    "build:packages": "pnpm -r --filter \"./packages/**\" run build",
    "build:sites": "pnpm -r --filter \"./sites/**\" run build",
    "build:veil": "pnpm -r --filter \"./packages/**\" run build && pnpm --filter @veil-ncss/site-veil run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint && pnpm lint:components",
    "lint:components": "tsx tools/lint-components.ts",
    "test": "pnpm -r run test",
    "dev:veil": "pnpm --filter @veil-ncss/site-veil run dev",
    "a11y:check": "tsx scripts/a11y-check.ts",
    "smoke:two-brand": "tsx scripts/two-brand-smoke.ts",
    "harness": "node ./tools/serve-harness.mjs",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "vitest": "^1.4.0",
    "playwright": "^1.45.0",
    "@axe-core/playwright": "^4.10.0"
  }
}
