<!doctype html>
<html lang="en" data-brand="ncss">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} — {{ site.shortName or site.name }}{% else %}{{ site.name }}{% endif %}</title>
    {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@400..900&display=swap" />
    <link rel="stylesheet" href="/styles/site.css" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    {% block nav %}{% include "site-nav.njk" %}{% endblock %}
    <main id="main-content">
      {% block content %}{% endblock %}
    </main>
    {% include "site-footer.njk" %}
    {% include "quick-contact-bar.njk" %}
  </body>
</html>
